# Kubernetes aliases
if command -v kubectl &> /dev/null; then
    # Aliases
    alias kubectl='kubectl --context="$KUBECTL_CONTEXT" --namespace="$KUBECTL_NAMESPACE"'
    alias dev='k --context dev -n dev'
    alias idev='k --context idev -n dev'
    alias stage='k --context stage -n stg'
    alias testing='k --context qa'
    alias ops='k --context ops'
    alias prod='k --context prod -n prod'
    alias dr='k --context dr -n prod'
    alias bench='k --context benchmark'
    alias sand='k --context sandbox'
    alias ks='k -n kube-system'
    alias ka='k apply -f'
    alias kd='k describe'
    alias kdel='k delete -f'
    alias krm='kdel'
    alias kg='k get'
    alias kgp='kg pod'
    alias kdp='kd pod'
    alias kgpy='kgp -o yaml'
    alias kgpj='kgp -o json'
    alias kgpa='kgp -A'
    alias kgpw='kgp -w'
    alias kgd='kg deploy'
    alias kgdy='kgd -o yaml'
    alias kgdj='kgd -o json'
    alias kgda='kgd -A'
    alias kgdw='kgd -w'
    alias kdd='kd deploy'
    alias kgss='kg statefulsets'
    alias kgssy='kgss -o yaml'
    alias kgssj='kgss -o json'
    alias kgsa='kg sa'
    alias kgsay='kgsa -o yaml'
    alias kgsaj='kgsa -o json'
    alias kgpv='kg pv'
    alias kgpvc='kg pvc'
    alias kgsc='kg sc'
    alias kgrs='kg rs'
    alias kgrsy='kg rs -o yaml'
    alias kgrsj='kg rs -o json'
    alias kgn='kg nodes'
    alias kdn='kd nodes'
    alias kdpv='kd pv'
    alias kdpvc='kd pvc'
    alias kex='k exec -it'
    alias kx='kex'
    alias kl='k logs'
    alias klf='kl -f'
    alias klp='kl --previous'
    alias krr='k rollout restart'
    alias kgsec='kg secrets'
    alias kgsecy='kgsec -o yaml'
    alias kgsecj='kgsec -o json'
    alias kgns='kg ns'
    alias kgcm='kg cm'
    alias kgcmy='kgcm -o yaml'
    alias kgcmj='kgcm -o json'
    alias kge='kg events'
    alias kdi='kd ingress'
    alias kgi='kg ingress'
    alias kgia='kg ingress -A'
    alias kgiy='kgi -o yaml'
    alias kgij='kgi -o json'
    alias kds='kd service'
    alias kgs='kg service'
    alias kgsa='kgs -A'
    alias kgsy='kgs -o yaml'
    alias kgsj='kgs -o json'
    alias kgy='kg -o yaml'
    alias kgj='kg -o json'
    alias kt='k top'
    alias ktn='kt nodes'
    alias ktp='kt pods'
    alias ktpc='ktp --containers'
    alias kpf='k port-forward'

    # ====================== KUBECTL HELPERS ======================
    # Switch kubeconfig file
    kswitch() {
      if [ -z "$1" ]; then
        echo "Usage: kswitch <config-name>"
        echo "Available configs in ~/.kube/configs/:"
        ls -1 ~/.kube/configs/ 2>/dev/null || echo "No configs found."
        return 1
      fi

      export KUBECONFIG="$HOME/.kube/configs/$1"
      echo "✅ Switched kubeconfig → $KUBECONFIG"
      kubectl config current-context
    }

    # Switch context (within current kubeconfig)
    kctx() {
      if [ -z "$1" ]; then
        echo "Current context: $(kubectl config current-context 2>/dev/null || echo 'None')"
        echo "Available contexts:"
        kubectl config get-contexts --no-headers -o name | cat -n
        return 0
      fi

      kubectl config use-context "$1" && \
      export KUBECTL_CONTEXT="$1" && \
      echo "✅ Context switched to: $1"
    }

    # Switch namespace
    kns() {
      if [ -z "$1" ]; then
        echo "Current namespace: ${KUBECTL_NAMESPACE:-default}"
        echo "Available namespaces:"
        kubectl get namespaces --no-headers -o custom-columns=NAME:.metadata.name
        return 0
      fi

      kubectl config set-context --current --namespace="$1" && \
      export KUBECTL_NAMESPACE="$1" && \
      echo "✅ Namespace set to: $1"
    }

    # Optional: Show current status
    kstatus() {
      echo "KUBECONFIG       : ${KUBECONFIG:-$HOME/.kube/config}"
      echo "Context          : ${KUBECTL_CONTEXT:-$(kubectl config current-context 2>/dev/null)}"
      echo "Namespace        : ${KUBECTL_NAMESPACE:-default}"
    }

    # Stern
    if command -v stern &> /dev/null; then
        alias stern='stern --context="$KUBECTL_CONTEXT" --namespace="$KUBECTL_NAMESPACE" --tail 120'
        alias plogs='stern --context prod -n prod --tail 20'
        alias slogs='stern --context stage -n stg --tail 20'
        alias dlogs='stern --context dev -n dev --tail 20'
        alias logs='stern --context "$KUBECTL_CONTEXT" -n "$KUBECTL_NAMESPACE"'
    fi

    # Helm
    if command -v helm &> /dev/null; then
        alias helm='helm --kube-context="$KUBECTL_CONTEXT" --namespace="$KUBECTL_NAMESPACE"'
    fi

    # K9S
    if command -v k9s &> /dev/null; then
        alias k9s='k9s --context="$KUBECTL_CONTEXT" --namespace="$KUBECTL_NAMESPACE" --splashless'
    fi

    # Krew
    [[ -d $HOME/.krew ]] && export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

fi
